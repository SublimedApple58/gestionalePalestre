{
  "name": "gestionale",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm db:generate && pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "pnpm --filter web lint",
    "db:generate": "pnpm --filter @gestionale/db db:generate",
    "db:push": "pnpm --filter @gestionale/db db:push",
    "db:migrate": "pnpm --filter @gestionale/db db:migrate",
    "db:studio": "pnpm --filter @gestionale/db db:studio",
    "postinstall": "pnpm db:generate"
  }
}
