generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  INSTRUCTOR
  SUBSCRIBER
}

enum SubscriptionTier {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum AccessEventType {
  ENTRY_SIMULATION
  DOOR_OPEN
}

enum DocumentType {
  TAX_CODE
  IDENTITY_DOCUMENT
  MEDICAL_CERTIFICATE
  PROFILE_PHOTO
}

enum DocumentSide {
  FRONT
  BACK
  SINGLE
}

enum DocumentStatus {
  UPLOADED
  AI_PROCESSING
  NEEDS_REUPLOAD
  PENDING_ADMIN_REVIEW
  APPROVED
  REJECTED
}

enum DocumentJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  ESCALATED
}

model User {
  id                    String             @id @default(cuid())
  firstName             String
  lastName              String
  email                 String             @unique
  phoneNumber           String?
  address               String?
  passwordHash          String
  role                  UserRole           @default(SUBSCRIBER)
  accessCode            String             @db.VarChar(6)
  dateOfBirth           DateTime?
  assignedInstructorId  String?
  assignedInstructor    User?              @relation("InstructorAssignments", fields: [assignedInstructorId], references: [id], onDelete: SetNull)
  assignedSubscribers   User[]             @relation("InstructorAssignments")
  subscription          UserSubscription?
  workoutPlan           WorkoutPlan?
  accessEvents          AccessEvent[]
  documents             UserDocument[]     @relation("UserDocuments")
  uploadedDocuments     UserDocument[]     @relation("UserUploadedDocuments")
  reviewedDocuments     UserDocument[]     @relation("UserReviewedDocuments")
  documentJobs          DocumentProcessingJob[]
  sessions              Session[]
  accounts              Account[]
  subscriptionsAssigned UserSubscription[] @relation("AdminAssignedSubscriptions")
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([role])
  @@index([assignedInstructorId])
}

model UserDocument {
  id                          String         @id @default(cuid())
  userId                      String
  type                        DocumentType
  side                        DocumentSide   @default(SINGLE)
  status                      DocumentStatus @default(UPLOADED)
  storageKey                  String
  fileName                    String
  fileLabel                   String
  mimeType                    String
  sizeBytes                   Int
  sha256                      String         @db.VarChar(64)
  uploadedById                String?
  uploadedAt                  DateTime       @default(now())
  aiAttempts                  Int            @default(0)
  aiConfidence                Float?
  aiLastError                 String?
  extractedTaxCode            String?        @db.VarChar(16)
  extractedIdentityNumber     String?        @db.VarChar(20)
  extractedDateOfBirth        DateTime?
  medicalCertificateExpiresAt DateTime?
  reviewedById                String?
  reviewedAt                  DateTime?
  rejectionReason             String?
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt
  user                        User           @relation("UserDocuments", fields: [userId], references: [id], onDelete: Cascade)
  uploadedBy                  User?          @relation("UserUploadedDocuments", fields: [uploadedById], references: [id], onDelete: SetNull)
  reviewedBy                  User?          @relation("UserReviewedDocuments", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([userId, type, side])
  @@index([userId, type, status])
  @@index([status, uploadedAt(sort: Desc)])
  @@index([uploadedById])
  @@index([reviewedById])
}

model DocumentProcessingJob {
  id           String            @id @default(cuid())
  userId       String
  type         DocumentType
  status       DocumentJobStatus @default(QUEUED)
  attemptCount Int               @default(0)
  maxAttempts  Int               @default(3)
  nextRunAt    DateTime          @default(now())
  lastError    String?
  payload      Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, nextRunAt, createdAt])
  @@index([userId, type, status])
}

model UserSubscription {
  id           String           @id @default(cuid())
  userId       String           @unique
  tier         SubscriptionTier
  startsAt     DateTime
  endsAt       DateTime
  assignedById String?
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedBy   User?            @relation("AdminAssignedSubscriptions", fields: [assignedById], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([startsAt, endsAt])
  @@index([assignedById])
}

model WorkoutPlan {
  id        String   @id @default(cuid())
  userId    String   @unique
  monday    String?
  tuesday   String?
  wednesday String?
  thursday  String?
  friday    String?
  saturday  String?
  sunday    String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AccessEvent {
  id         String          @id @default(cuid())
  userId     String
  eventType  AccessEventType
  note       String?
  occurredAt DateTime        @default(now())
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt(sort: Desc)])
  @@index([occurredAt(sort: Desc)])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
