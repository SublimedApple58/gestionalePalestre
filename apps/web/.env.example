DATABASE_URL="postgresql://USER:PASSWORD@YOUR-POOLER-HOST.neon.tech/DB_NAME?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@YOUR-DIRECT-HOST.neon.tech/DB_NAME?sslmode=require"
AUTH_SECRET="replace-with-strong-random-secret"
AUTH_URL="http://localhost:3000"
SEED_ADMIN_EMAIL="umberto.giancola00@gmail.com"
SEED_ADMIN_PASSWORD="Castiglione1!"

# OpenAI document extraction
OPENAI_API_KEY="sk-..."
OPENAI_DOCS_MODEL="gpt-4.1-mini"
DOC_AI_MIN_CONFIDENCE="0.85"
DOC_AI_MAX_RETRIES="3"

# Cloudflare R2
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="gestionale-documents"
R2_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"

# Upload/processing tuning
DOC_UPLOAD_MAX_BYTES="12582912"
DOC_PRESIGN_TTL_SECONDS="300"
DOC_JOB_BATCH_SIZE="10"
DOC_RATE_LIMIT_WINDOW_MS="60000"
DOC_RATE_LIMIT_MAX_REQUESTS="30"

# Cron protection
CRON_SECRET="replace-with-long-random-secret"
